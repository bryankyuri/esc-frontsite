# Frontend build config.
#
# PRODUCTION (Vercel): set VITE_API_BASE_URL in the Vercel project's
# Environment Variables — do NOT commit the real value. Point it at the backend
# API's HTTPS domain, no trailing slash, e.g.:
#   VITE_API_BASE_URL=https://api-dictionary.earhousesongwritingclub.com
#
# LOCAL DEV: leave it unset and the app falls back to http://localhost:8002,
# or point it at your local backend:
VITE_API_BASE_URL=http://localhost:8002
